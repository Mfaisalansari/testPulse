# Default: auto-detect text vs binary; normalize text to LF in the repo
* text=auto eol=lf

# Source files always LF
*.java        text eol=lf
*.xml         text eol=lf
*.md          text eol=lf
*.yml         text eol=lf
*.yaml        text eol=lf
*.properties  text eol=lf
*.json        text eol=lf
*.sh          text eol=lf

# Windows scripts keep CRLF
*.bat         text eol=crlf
*.cmd         text eol=crlf

# Binary — never modify
*.jar         binary
*.war         binary
*.png         binary
*.jpg         binary
*.jpeg        binary
*.gif         binary
*.ico         binary
*.zip         binary
